# Alpaca API credentials
# Copy to .env and fill in your keys from https://app.alpaca.markets

APCA_PAPER=true

# Paper trading credentials
APCA_PAPER_KEY=your_paper_key_here
APCA_PAPER_SECRET_KEY=your_paper_secret_here

# Live trading credentials
APCA_REAL_KEY=your_real_key_here
APCA_REAL_SECRET_KEY=your_real_secret_here

# Fallback (used if mode-specific keys not set)
# APCA_API_KEY_ID=your_key_here
# APCA_API_SECRET_KEY=your_secret_here
